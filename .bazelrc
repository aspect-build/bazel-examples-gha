# Import bazelrc presets
import %workspace%/tools/java17.bazelrc
import %workspace%/tools/preset.bazelrc
# Aspect Workflows / RBE config (`--config=rbe`, etc.). Previously loaded
# implicitly by `rosetta run` via `--bazelrc=.aspect/workflows/bazelrc`;
# aspect-cli doesn't pass that flag, so import it here instead.
import %workspace%/.aspect/workflows/bazelrc

### YOUR PROJECT SPECIFIC OPTIONS GO HERE ###
# common --repo_env=RUBY_CONFIGURE_OPTS=--with-out-ext=psych
common --modify_execution_info=GemInstall=+no-remote-exec,BundleInstall=+no-remote-exec

# We have a lot of dependencies and are okay with some of them bringing a newer version via a transitive dep.
common --check_direct_dependencies=off

# When running locally, warn about unconfigured git hooks.
common --workspace_status_command=githooks/check-config.sh
# But not on CI.
common:ci --workspace_status_command=

# 'bazel build --config=lint' will produce the linter reports.
# `aspect lint` (via aspect_rules_lint's lint.axl task) reuses this config.
build:lint --aspects=//tools/lint:linters.bzl%buf
build:lint --aspects=//tools/lint:linters.bzl%checkstyle
build:lint --aspects=//tools/lint:linters.bzl%clippy
build:lint --aspects=//tools/lint:linters.bzl%eslint
build:lint --aspects=//tools/lint:linters.bzl%pmd
build:lint --aspects=//tools/lint:linters.bzl%ruff
build:lint --aspects=//tools/lint:linters.bzl%shellcheck
# Request linters produce human-readable output rather than machine-readable
build:lint --output_groups=+rules_lint_human

# Required for isolated extension usages (needed for keep-sorted dependency)
common --experimental_isolated_extension_usages
build:lint --aspects=//tools/lint:linters.bzl%keep_sorted

# for speed, passes an argument `--skipLibCheck` to *every* spawn of tsc
common --@aspect_rules_ts//ts:skipLibCheck=always
# use `tsc` for transpiling, even though it's slow.
# TODO(alex): change to SWC by default
common --@aspect_rules_ts//ts:default_to_tsc_transpiler

# To stamp release builds, run with
# --config=release
common:release --stamp --workspace_status_command=./tools/workspace_status.sh

# Allow resolving protoc from a pre-built toolchain
common --incompatible_enable_proto_toolchain_resolution

# toolchains_protoc 0.6.1 ships at most protoc v33.0, but the resolved
# `protobuf` BCR module is 33.4. Skip the strict version match instead of
# downgrading every transitive consumer of protobuf.
common --@protobuf//bazel/toolchains:allow_nonstandard_protoc

# Register the hermetic LLVM toolchain only on Linux. On macOS the toolchain
# ships without a sysroot, which causes the linker to fail on libSystem
# symbols (e.g. _strtoll); rely on apple_support's local Xcode toolchain
# instead.
build:linux --extra_toolchains=@llvm_toolchain//:all
build:linux_x86_64 --extra_toolchains=@llvm_toolchain//:all
build:linux_aarch64 --extra_toolchains=@llvm_toolchain//:all
common --enable_platform_specific_config

# `std::filesystem` is gated behind macOS 10.15. Without explicitly setting
# the deployment target the apple_support toolchain falls back to an older
# default (10.13/10.14) and rejects filesystem APIs.
build:macos --macos_minimum_os=11.0
build:macos --copt=-mmacosx-version-min=11.0
build:macos --linkopt=-mmacosx-version-min=11.0

# Don't depend on a JAVA_HOME pointing at a system JDK
# see https://github.com/bazelbuild/rules_jvm_external/issues/445
build --repo_env=JAVA_HOME=../bazel_tools/jdk

# In support of py_mypy/...

# register mypy_aspect with Bazel
build --aspects //tools/mypy:defs.bzl%mypy_aspect

# optionally, default enable the mypy checks
build --output_groups=+mypy

# Load any settings & overrides specific to the current user.
# This file should appear in `.gitignore` so that settings are not shared with team members. This
# should be last statement in this config so the user configuration is able to overwrite flags from
# this file. See https://bazel.build/configure/best-practices#bazelrc-file.
try-import %workspace%/user.bazelrc
